# ============================================================
# Notification Service Environment
# ============================================================
# Scope:
# - Copy to services/notification-service/.env for local standalone runs.
# - In production, inject these values only into notification-service by
#   Secret Manager, Kubernetes Secret, ECS Task Definition, or CI/CD secrets.
# - Do not share unrelated service secrets with notification-service.
# ============================================================

# Runtime
NODE_ENV=development
PORT=3005
APP_VERSION=1.0.0

# MongoDB - notification database
MONGODB_URI=mongodb://root:changeme_mongo@localhost:27017/bin_notification?authSource=admin

# Kafka - notification events
KAFKA_BROKERS=localhost:29092

# SMTP - outbound email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=replace-with-app-password
SMTP_FROM=noreply@binecommerce.local
